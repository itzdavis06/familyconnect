// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  fullName     String?
  dateOfBirth  DateTime?
  email        String?   @unique
  phone        String?
  occupation   String?
  location     String?
  createdAt    DateTime  @default(now())

   memberships           FamilyMember[]
  messages               Message[]
  sentDirectMessages     DirectMessage[] @relation("SentDirectMessages")
  receivedDirectMessages DirectMessage[] @relation("ReceivedDirectMessages")
}

model Family {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  members FamilyMember[]
  invitations Invitation[]
  messages    Message[]
}

model FamilyMember {
  id              String    @id @default(uuid())
  role            Role
  userId          String?
  familyId        String
  childFullName   String?
  childDateOfBirth DateTime?
  dateOfDeath     DateTime?
  createdByUserId String?

  user     User?         @relation(fields: [userId], references: [id])
  family   Family        @relation(fields: [familyId], references: [id])

  parentLinksAsChild  ParentLink[] @relation("LinkAsChild")
  parentLinksAsParent ParentLink[] @relation("LinkAsParent")

  @@unique([userId, familyId])
}

model ParentLink {
  id       String @id @default(uuid())
  parentId String
  childId  String

  parent FamilyMember @relation("LinkAsParent", fields: [parentId], references: [id])
  child  FamilyMember @relation("LinkAsChild", fields: [childId], references: [id])

  @@unique([parentId, childId])
}

enum Role {
  ADMIN
  PARENT
  MEMBER
  CHILD
  ANCESTOR
}

model Invitation {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  familyId  String
  role      Role     @default(MEMBER)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  family Family @relation(fields: [familyId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  familyId  String
  senderId  String
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id])
  sender User   @relation(fields: [senderId], references: [id])
}

model DirectMessage {
  id          String   @id @default(uuid())
  content     String
  senderId    String
  recipientId String
  createdAt   DateTime @default(now())

  sender    User @relation("SentDirectMessages", fields: [senderId], references: [id])
  recipient User @relation("ReceivedDirectMessages", fields: [recipientId], references: [id])
}